    "source": "\\b(rm\\s+-rf|reset\\s+--hard|push\\s+--force|kill\\s+-9|chmod|chown|restart|--delete|--yolo|dangerously-bypass)\\b|(^|\\s)>(?!>)",
    "flags": "i"
  },
  "possibleSecret": {
    "source": "api[_-]?key|secret|token\\s*[=:]\\s*[a-z0-9_-]{12,}",
    "flags": "i"
  }
}
