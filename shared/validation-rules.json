{
  "_comment": "校验规则单一来源。validate-data.js 直接消费；host.py 必须镜像同样的值，由 tests/test_validation_consistency.js 防止漂移。改这里后同步更新 host.py 常量。",
  "keywords": { "min": 3, "max": 8 },
  "examples": { "max": 3 },
  "sourceTiers": ["official", "quasi-official", "community"],
  "quasiOfficialDomains": [
    "tldr.sh",
    "man7.org",
    "ss64.com",
    "manpages.debian.org",
    "developer.mozilla.org",
    "wiki.archlinux.org",
    "devhints.io",
    "cheat.sh",
    "readthedocs.io"
  ],
  "dangerousExample": {
    "source": "(?:\\brm(?:\\s|$)|\\b(?:reset\\s+--hard|push\\s+--force|kill\\s+-9|chmod|chown|restart)\\b|--(?:delete|yolo)\\b|dangerously-bypass\\b)|(^|\\s)>(?!>)",
    "flags": "i"
  },
  "riskLevels": {
    "deleteOrOverwrite": "(?:\\brm(?:\\s|$)|\\breset\\s+--hard\\b|--delete\\b)|(^|\\s)>(?!>)",
    "permissionChange": "\\b(chmod|chown)\\b",
    "historyRewrite": "\\b(reset\\s+--hard|push\\s+--force|rebase\\s+-i)\\b",
    "safetyBypass": "(?:--yolo|dangerously-bypass)\\b",
    "processDisruption": "\\b(kill\\s+-9|restart)\\b"
  },
  "possibleSecret": {
    "source": "api[_-]?key|secret|token\\s*[=:]\\s*[a-z0-9_-]{12,}",
    "flags": "i"
  }
}
